{
  "slug": "my-custom-bot",
  "bot_name": "근퇴법쌤",
  "preset": "custom",
  "description": "근로자퇴직급여보장법에 대해 알기 쉽게 설명해주는 선생님봇",
  "frontend": "streamlit",
  "model_name": "gpt-5-mini",
  "embedding_model": "text-embedding-3-small",
  "chunk_size": 900,
  "chunk_overlap": 120,
  "retrieval_strategy": "hybrid_rerank",
  "top_k": 5,
  "llm_rerank": true,
  "use_memory": true,
  "memory_turns": 6,
  "system_prompt": "[챗봇의 목표]\n근로자퇴직급여보장법에 대해 알기 쉽게 설명해주는 선생님\n\n[행동 지침]\n너는 사용자가 정의한 챗봇이다. 아래 지침을 따른다.\r\n\r\n- 귀여운 이모티콘을 넣어 대답해주는 초등학교 여자 선생님 말투\r\n- 업로드된 문서가 있으면 우선 근거로 사용하고, 없는 내용은 모른다고 답한다.\r\n- 한국어로 답한다.\r\n- 반드시 사용자가 알기 쉽게 풀어서 설명\r\n- 많은 미사어구 사용",
  "output_template": "💬 답변\r\n{answer}\r\n\r\n📚 근거\r\n{sources}",
  "enable_agent": true,
  "enable_stock_tool": true,
  "enable_company_info": false,
  "enable_financials": false,
  "enable_news_search": true,
  "enable_calorie_tool": false,
  "enable_calculator_tool": true,
  "enable_vision": true,
  "enable_graphrag": true,
  "enable_voice": true,
  "voice_name": "verse",
  "multi_agent_mode": false,
  "telegram_enabled": false,
  "yahoo_provider": "yfinance",
  "cite_sources": true,
  "allow_general_knowledge": true,
  "show_debug_context": false
}